<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 04, Day 1: Through the Black Forest Edge to Tübingen</name>
    <desc>Head south through Bretten and Maulbronn (UNESCO monastery) to Pforzheim, then into the Black Forest edge via Calw and the Nagold valley. Wind through Haiterbach and Horb am Neckar, following the young Neckar river to Rottenburg (bishop’s town) and on to Tübingen.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <wpt lat="49.036000" lon="8.707000">
    <name>Bretten</name>
    <desc>Melanchthon town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.002000" lon="8.812000">
    <name>Maulbronn</name>
    <desc>UNESCO monastery</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.891000" lon="8.704000">
    <name>Pforzheim</name>
    <desc>Northern BF gate</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.714000" lon="8.741000">
    <name>Calw</name>
    <desc>Hermann Hesse</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.551000" lon="8.724000">
    <name>Nagold</name>
    <desc>Nagold valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.521000" lon="8.647000">
    <name>Haiterbach</name>
    <desc>Black Forest edge</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.445000" lon="8.692000">
    <name>Horb am Neckar</name>
    <desc>Neckar valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.476000" lon="8.935000">
    <name>Rottenburg am Neckar</name>
    <desc>Cathedral town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.522000" lon="9.057000">
    <name>Tübingen</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
