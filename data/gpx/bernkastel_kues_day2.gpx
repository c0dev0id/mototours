<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 02, Day 2: Nahe Valley &amp; Pfalz Return</name>
    <desc>Follow the Moselle south to Neumagen-Dhron (Germany’s oldest wine town), then climb back over the Hunsrück to Idar-Oberstein. Pick up the Nahe valley at Kirn and follow this beautiful, underrated wine river east through Bad Sobernheim and Bad Kreuznach. Cross into the Pfalz at Bad Dürkheim and ride the Weinstraße south to Speyer.</desc>
  </metadata>
  <wpt lat="49.915000" lon="7.068000">
    <name>Bernkastel-Kues</name>
    <desc>Start day 2</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.854000" lon="6.895000">
    <name>Neumagen-Dhron</name>
    <desc>Oldest wine town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.754000" lon="7.010000">
    <name>Thalfang</name>
    <desc>Hunsrück</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.714000" lon="7.308000">
    <name>Idar-Oberstein</name>
    <desc>Gemstone gorge</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.789000" lon="7.455000">
    <name>Kirn</name>
    <desc>Nahe valley</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.783000" lon="7.647000">
    <name>Bad Sobernheim</name>
