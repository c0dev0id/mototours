    <type>Via</type>
  </wpt>
  <wpt lat="49.462000" lon="8.172000">
    <name>Bad Dürkheim</name>
    <desc>Wine barrel</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.355000" lon="8.142000">
    <name>Neustadt a.d. Weinstraße</name>
    <desc>Wine route</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End – home</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
