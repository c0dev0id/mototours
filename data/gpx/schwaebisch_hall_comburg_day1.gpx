  <metadata>
    <name>Tour 22: Schwäbisch Hall &amp; Comburg</name>
    <desc>A full-day ride to one of southern Germany’s most spectacular medieval towns—Schwäbisch Hall, with its theatrical market square—and the imposing Comburg monastery fortress perched on a hill above.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
