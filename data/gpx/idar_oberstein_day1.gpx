<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 10, Day 1: Pfälzerwald &amp; Hunsrück to Idar-Oberstein</name>
    <desc>Cross the Rhine at Speyer and ride through the Pfälzerwald to Johanniskreuz. Continue northwest through Lauterecken and the medieval town of Meisenheim, then up the Nahe to Kirn and Idar-Oberstein.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.355000" lon="8.142000">
    <name>Neustadt a.d. Weinstraße</name>
    <desc>Wine route</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.348000" lon="7.850000">
    <name>Johanniskreuz</name>
    <desc>Biker crossroads</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.650000" lon="7.588000">
    <name>Lauterecken</name>
    <desc>Glan valley</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.708000" lon="7.669000">
    <name>Meisenheim</name>
    <desc>Medieval gem</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.789000" lon="7.455000">
    <name>Kirn</name>
    <desc>Nahe valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.714000" lon="7.308000">
    <name>Idar-Oberstein</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
  <rte>
    <name>Pfälzerwald &amp; Hunsrück to Idar-Oberstein</name>
    <desc>~200 km</desc>
    <rtept lat="49.322000" lon="8.548000">
      <name>Hockenheim</name>
    </rtept>
    <rtept lat="49.317000" lon="8.431000">
      <name>Speyer</name>
    </rtept>
