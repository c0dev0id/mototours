<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 09, Day 1: Alsace Wine Route to Munster</name>
    <desc>Cross the Rhine south of Baden-Baden and ride through Haguenau to the Alsace Wine Route. Head south through a parade of half-timbered villages—Obernai, Barr, Andlau, Ribeauvillé, Kaysersberg—to the Munster valley.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <wpt lat="48.761000" lon="8.241000">
    <name>Baden-Baden</name>
    <desc>Head south (via A5)</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.822000" lon="8.148000">
    <name>Iffezheim</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.815000" lon="7.791000">
    <name>Haguenau</name>
    <desc>French side</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.462000" lon="7.483000">
    <name>Obernai</name>
    <desc>Alsatian gem</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.407000" lon="7.449000">
    <name>Barr</name>
    <desc>Wine capital</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.387000" lon="7.417000">
    <name>Andlau</name>
    <desc>Romanesque abbey</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.194000" lon="7.318000">
    <name>Ribeauvillé</name>
    <desc>Three castles</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.140000" lon="7.264000">
    <name>Kaysersberg</name>
    <desc>Albert Schweitzer</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.042000" lon="7.137000">
    <name>Munster</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
