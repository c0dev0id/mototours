  <metadata>
    <name>Tour 18: Alsace Wine Route</name>
    <desc>Cross into France for a day on the famous Route des Vins d’Alsace—half-timbered villages, vineyards climbing steep hillsides, and some of the best food in Europe. Alsatian cuisine is the perfect midpoint reward.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
