    <desc>Gemstone city</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.810000" lon="7.130000">
    <name>Morbach</name>
    <desc>Hunsrück</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.915000" lon="7.068000">
    <name>Bernkastel-Kues</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
