<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 05, Day 1: Through Central Black Forest to Staufen</name>
    <desc>Head south through Pforzheim and Calw into the Black Forest via the Nagoldtal to Freudenstadt. Continue to the stunning half-timbered Schiltach, then through Wolfach and the Elztal to Waldkirch. Pass Freiburg to reach Staufen.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="48.891000" lon="8.704000">
    <name>Pforzheim</name>
    <desc>Gold City</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.714000" lon="8.741000">
    <name>Calw</name>
    <desc>Hermann Hesse’s town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.462000" lon="8.411000">
    <name>Freudenstadt</name>
    <desc>Marktplatz</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.290000" lon="8.339000">
    <name>Schiltach</name>
    <desc>Half-timbered gem</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.293000" lon="8.219000">
    <name>Wolfach</name>
    <desc>Glassblowing</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.173000" lon="8.071000">
    <name>Elzach</name>
    <desc>Elztal</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.094000" lon="7.959000">
    <name>Waldkirch</name>
    <desc>Kandel views</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="47.999000" lon="7.842000">
    <name>Freiburg outskirts</name>
    <desc>BF capital bypass</desc>
    <type>Via</type>
    <sym>Summit</sym>
  </wpt>
  <wpt lat="47.883000" lon="7.728000">
    <name>Staufen im Breisgau</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
