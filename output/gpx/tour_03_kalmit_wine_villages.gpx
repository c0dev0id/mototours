    <desc>Wine village</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.283267" lon="8.119929">
    <name>Edenkoben</name>
    <desc>Villa Ludwigshöhe</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.117000" lon="8.052000">
    <name>Gleiszellen-Gleishorbach</name>
    <desc>Southern wine route</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.100000" lon="8.001000">
    <name>Bad Bergzabern</name>
    <desc>Spa town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.199000" lon="8.117000">
    <name>Landau in der Pfalz</name>
    <desc>Return north</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End</desc>
    <sym>Flag, Blue</sym>
    <type>End</type>
  </wpt>
