  <metadata>
    <name>Tour6d 05, Day 3: Thüringer Wald to Meiningen</name>
    <desc>Along the Rennsteig ridge via Oberhof, loop north to the Inselsberg area through Tabarz and Friedrichroda, then south to Schmalkalden and Meiningen.</desc>
  </metadata>
  <wpt lat="50.685000" lon="10.919000">
    <name>Ilmenau</name>
    <desc>Start</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="50.723390" lon="10.733090">
