    <type>Via</type>
  </wpt>
  <wpt lat="49.253000" lon="9.919000">
    <name>Gerabronn</name>
    <desc>Rolling farmland</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.134000" lon="10.072000">
    <name>Crailsheim</name>
    <desc>Eastern edge</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.112000" lon="9.738000">
    <name>Schwäbisch Hall</name>
    <desc>Bypass south</desc>
