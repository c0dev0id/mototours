<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 23: Hohenloher Land</name>
    <desc>Discover the gentle hills and castle-studded villages of the Hohenloher Land—“the Balcony of Franconia”—with its aristocratic residences, car museum at Langenburg, and sweeping views from Waldenburg’s ridge-top setting.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.253000" lon="8.879000">
    <name>Sinsheim</name>
    <desc>Head east</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.239000" lon="8.993000">
    <name>Bad Rappenau</name>
    <desc>Saline</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.192000" lon="9.225000">
    <name>Neckarsulm</name>
    <desc>Motorcycle Museum</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.201000" lon="9.501000">
    <name>Öhringen</name>
    <desc>Hohenlohe residency</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.201000" lon="9.578000">
