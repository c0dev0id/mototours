<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 21: Jagsttal &amp; Kochertal</name>
    <desc>Explore the peaceful Jagst and Kocher valleys—parallel river valleys winding through the gentle Hohenloher Land, where time seems to have stopped in the Baroque era. Discover monasteries, castles, and the Deutsches Zweirad-Museum (German Motorcycle Museum) in Neckarsulm.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
