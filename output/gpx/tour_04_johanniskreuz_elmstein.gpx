  <metadata>
    <name>Tour 04: Johanniskreuz – Heart of the Pfälzerwald</name>
    <desc>Ride through the enchanting Elmstein Valley, the scenic gorge slicing through the Pfälzerwald, to reach Johanniskreuz—the legendary forest crossroads that has been a favorite biker meeting point for decades.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
