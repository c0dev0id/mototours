  </wpt>
  <wpt lat="49.676000" lon="9.004000">
    <name>Michelstadt</name>
    <desc>Fairy-tale Rathaus – midpoint</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.659000" lon="8.994000">
    <name>Erbach</name>
    <desc>Ivory museum</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.710000" lon="8.837000">
    <name>Reichelsheim</name>
    <desc>Continue south</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.568435" lon="8.780766">
    <name>Lindenfels</name>
    <desc>Pearl of the Odenwald</desc>
