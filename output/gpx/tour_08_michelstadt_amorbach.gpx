<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 08: Deep Odenwald – Michelstadt &amp; Amorbach</name>
    <desc>Penetrate the most remote reaches of the Odenwald to discover Amorbach’s stunning Baroque abbey and Michelstadt’s fairy-tale medieval Rathaus. Long stretches through dark forest with barely a village in sight.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.409000" lon="8.693000">
    <name>Heidelberg</name>
    <desc>Head east</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.393000" lon="8.797000">
    <name>Neckargemünd</name>
    <desc>Neckar valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.438000" lon="8.811000">
    <name>Schönau</name>
    <desc>Into the hills</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.454000" lon="9.103000">
    <name>Waldbrunn</name>
    <desc>Deep forest</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.534000" lon="9.208000">
