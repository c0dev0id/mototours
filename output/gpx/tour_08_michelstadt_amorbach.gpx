  </wpt>
  <wpt lat="49.681000" lon="8.618000">
    <name>Bensheim</name>
    <desc>Bergstraße</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End (via A5)</desc>
    <sym>Flag, Blue</sym>
    <type>End</type>
  </wpt>
