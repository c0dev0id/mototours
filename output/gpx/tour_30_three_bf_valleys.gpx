<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 30: Three Black Forest Valleys</name>
    <desc>Three distinct Black Forest valleys in one tour—climb through Bühlertal to the B500, descend into the flower-bedecked village of Sasbachwalden, then ride the Renchtal south before looping back through Freudenstadt.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <wpt lat="48.696000" lon="8.136000">
    <name>Bühl</name>
    <desc>Enter Black Forest (via A5)</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.669000" lon="8.168000">
    <name>Bühlertal</name>
    <desc>Valley climb</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.654000" lon="8.226000">
    <name>Sand</name>
    <desc>B500 junction</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.620000" lon="8.210000">
    <name>Unterstmatt</name>
    <desc>Leave B500 west</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.619000" lon="8.120000">
    <name>Sasbachwalden</name>
    <desc>Flower village – midpoint</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.628000" lon="8.075000">
    <name>Achern</name>
    <desc>Ortenau</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.528000" lon="8.078000">
    <name>Oberkirch</name>
    <desc>Renchtal</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.474000" lon="8.161000">
    <name>Oppenau</name>
    <desc>Deep Renchtal</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.427000" lon="8.202000">
    <name>Bad Peterstal-Griesbach</name>
    <desc>Spa</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.462000" lon="8.411000">
    <name>Freudenstadt</name>
    <desc>Marktplatz</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.714000" lon="8.741000">
    <name>Calw</name>
    <desc>Hermann Hesse’s birthplace</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.891000" lon="8.704000">
    <name>Pforzheim</name>
    <desc>Gold City</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <rte>
    <name>Tour 30: Three Black Forest Valleys</name>
    <desc>Schwarzwald | ~320 km | Moderate</desc>
