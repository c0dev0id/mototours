    <name>Waldfischbach-Burgalben</name>
    <desc>Forest road</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.431000" lon="7.894000">
    <name>Hochspeyer</name>
    <desc>Northern Pfälzerwald</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.355000" lon="8.142000">
    <name>Neustadt a.d. Weinstraße</name>
