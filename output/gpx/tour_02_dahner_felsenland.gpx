<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 02: Dahner Felsenland – Sandstone Wonders</name>
    <desc>Ride into the dramatic Dahner Felsenland, where massive sandstone towers and bizarre rock formations rise from dense forest. This is the wildest landscape in the Pfälzerwald, with twisting roads carved through a geological wonderland.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.199000" lon="8.117000">
    <name>Landau in der Pfalz</name>
    <desc>Head south</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.204000" lon="7.969000">
    <name>Annweiler am Trifels</name>
    <desc>Enter the forest</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.192000" lon="7.855000">
    <name>Hauenstein</name>
