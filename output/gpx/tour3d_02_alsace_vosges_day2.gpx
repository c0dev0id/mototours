      <name>Barr</name>
    </rtept>
    <rtept lat="48.194000" lon="7.318000">
      <name>Ribeauvillé</name>
    </rtept>
    <rtept lat="48.167000" lon="7.298000">
      <name>Riquewihr</name>
    </rtept>
    <rtept lat="48.140544" lon="7.263610">
      <name>Kaysersberg</name>
    </rtept>
    <rtept lat="48.042000" lon="7.137000">
      <name>Munster</name>
    </rtept>
    <rtept lat="48.063389" lon="7.023751">
      <name>Col de la Schlucht</name>
    </rtept>
    <rtept lat="48.073000" lon="6.879000">
