    <type>Via</type>
  </wpt>
  <wpt lat="48.407000" lon="8.015000">
    <name>Gengenbach</name>
    <desc>Nice of the BF</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.619000" lon="8.120000">
