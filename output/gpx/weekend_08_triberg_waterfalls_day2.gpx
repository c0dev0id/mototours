<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 08, Day 2: Gutachtal &amp; Schwarzwaldhochstraße Home</name>
    <desc>Ride north through the Gutachtal past the Vogtsbauernhof, then through the Kinzigtal to beautiful Gengenbach. Climb to Sasbachwalden and join the B500 at Sand. Ride the Schwarzwaldhochstraße past the Mummelsee and descend through Baden-Baden. A5 north home.</desc>
  </metadata>
  <wpt lat="48.133000" lon="8.237000">
    <name>Triberg</name>
    <desc>Start day 2</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.212000" lon="8.228000">
    <name>Hornberg</name>
    <desc>Valley town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.256000" lon="8.180000">
    <name>Gutach (Vogtsbauernhof)</name>
    <desc>Open-air museum</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.282000" lon="8.175000">
