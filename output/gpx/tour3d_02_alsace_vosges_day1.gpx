<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Tour3d 02, Day 1: Pfälzerwald to Northern Alsace</name>
    <desc>Cross into France at Wissembourg, visit Château Fleckenstein, then ride to Bitche’s Vauban citadel. Cross the Col du Donon and descend to Obernai.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.037000" lon="7.945000">
    <name>Wissembourg</name>
    <desc>Cross into France</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.003000" lon="7.788000">
    <name>Lembach</name>
    <desc>Château Fleckenstein</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.952000" lon="7.643000">
    <name>Niederbronn-les-Bains</name>
    <desc>Thermal spa</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.052000" lon="7.430000">
    <name>Bitche</name>
    <desc>Vauban citadel</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.519625" lon="7.130593">
    <name>Col du Donon (727 m)</name>
    <desc>Vosges pass</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.479000" lon="7.220000">
    <name>Schirmeck</name>
    <desc>Vosges valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.462000" lon="7.483000">
    <name>Obernai</name>
    <desc>Overnight</desc>
    <sym>Hotel</sym>
    <type>Overnight</type>
  </wpt>
