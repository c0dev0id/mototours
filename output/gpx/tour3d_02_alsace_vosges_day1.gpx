  <metadata>
    <name>Tour3d 02, Day 1: Pfälzerwald to Northern Alsace</name>
    <desc>Cross into France at Wissembourg, visit Château Fleckenstein, then ride to Bitche’s Vauban citadel. Cross the Col du Donon and descend to Obernai.</desc>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
