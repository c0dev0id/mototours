<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 28: Pfälzerwald Grand Tour</name>
    <desc>The ultimate Pfälzerwald experience—a grand loop covering the entire forest from north to south. Bad Dürkheim’s famous Wurstmarkt grounds, the legendary Johanniskreuz, the wild Dahner Felsenland, and the wine route. A full day of forest riding.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
