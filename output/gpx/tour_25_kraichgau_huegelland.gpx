  <metadata>
    <name>Tour 25: Kraichgau Hügelland</name>
    <desc>Explore the Kraichgau—the rolling hill country between the Rhine and the Odenwald that’s often called the “land of a thousand hills.” Gentle curves through orchards and vineyards with the Burg Steinsberg as the panoramic highlight.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
