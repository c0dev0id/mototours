    <desc>Baroque bishop’s town</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="48.897000" lon="10.966000">
    <name>Solnhofen</name>
    <desc>Fossil limestone</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="48.851127" lon="10.488312">
    <name>Nördlingen</name>
    <desc>Ries crater</desc>
    <type>Via</type>
  </wpt>
