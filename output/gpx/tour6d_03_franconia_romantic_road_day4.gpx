  <metadata>
    <name>Tour6d 03, Day 4: Altmühltal to Dinkelsbühl</name>
    <desc>Through the Altmühltal to Eichstätt, Nördlingen’s meteor crater, and medieval Dinkelsbühl.</desc>
  </metadata>
  <wpt lat="49.452000" lon="11.077000">
    <name>Nürnberg</name>
    <desc>Start</desc>
    <type>Via</type>
  </wpt>
