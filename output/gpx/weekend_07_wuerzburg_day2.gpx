<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 07, Day 2: Tauber Valley &amp; Hohenlohe Return</name>
    <desc>Head south from Würzburg through Ochsenfurt and into the Tauber valley. Visit Bad Mergentheim (Teutonic Knights castle) and Weikersheim, then ride through Hohenlohe to Schwäbisch Hall. Return via Öhringen and Neckarsulm—stop at the Deutsches Zweirad-Museum!</desc>
  </metadata>
  <wpt lat="49.792000" lon="9.934000">
    <name>Würzburg</name>
    <desc>Start day 2</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.664000" lon="10.063000">
    <name>Ochsenfurt</name>
    <desc>Main valley south</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.623000" lon="9.663000">
    <name>Tauberbischofsheim</name>
    <desc>Tauber valley</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.565000" lon="9.710000">
    <name>Lauda-Königshofen</name>
    <desc>Wine town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.493000" lon="9.773000">
    <name>Bad Mergentheim</name>
    <desc>Teutonic Knights</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.479000" lon="9.896000">
    <name>Weikersheim</name>
    <desc>Palace</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.112000" lon="9.738000">
    <name>Schwäbisch Hall</name>
    <desc>Marktplatz</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.201000" lon="9.501000">
    <name>Öhringen</name>
    <desc>Hohenlohe</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.192000" lon="9.225000">
    <name>Neckarsulm</name>
    <desc>Motorcycle museum!</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.253000" lon="8.879000">
    <name>Sinsheim</name>
    <desc>Return west</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End – home</desc>
    <sym>Flag, Blue</sym>
    <type>Start/End</type>
  </wpt>
  <rte>
    <name>Tauber Valley &amp; Hohenlohe Return</name>
    <desc>~220 km</desc>
