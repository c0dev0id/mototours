    <type>Via</type>
  </wpt>
  <wpt lat="49.709000" lon="8.652000">
    <name>Auerbacher Schloss</name>
    <desc>Castle and viewpoint – midpoint</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.726000" lon="8.613000">
    <name>Zwingenberg</name>
    <desc>Oldest Bergstraße town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.740000" lon="8.638000">
    <name>Alsbach-Hähnlein</name>
    <desc>Continue north</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.765000" lon="8.648000">
    <name>Seeheim</name>
