<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tour Planner">
  <metadata>
    <name>Tour 09: Bergstraße &amp; Melibokus</name>
    <desc>A relaxed ride along the Bergstraße—Germany’s “spring garden” with its Mediterranean microclimate—combined with a loop through the western Odenwald hills and the panoramic Auerbacher Schloss.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.550000" lon="8.667000">
    <name>Weinheim</name>
    <desc>Castle gardens</desc>
    <type>Via</type>
    <sym>Castle</sym>
  </wpt>
  <wpt lat="49.563000" lon="8.707000">
    <name>Birkenau</name>
    <desc>Into Odenwald</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.560000" lon="8.728000">
    <name>Gorxheimertal</name>
    <desc>Hill country</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.621000" lon="8.761000">
    <name>Rimbach</name>
    <desc>Forest edge</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.568435" lon="8.780766">
