  <metadata>
    <name>Tour 19: Col de Saverne &amp; Vosges Loop</name>
    <desc>A grand cross-border loop from the Pfälzerwald into the French Vosges mountains via the Col de Saverne. Combines German forest roads with French mountain passes and the impressive Citadel of Bitche.</desc>
    <author>
      <name>Hockenheim Motorcycle Tours</name>
    </author>
  </metadata>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>Start/End</desc>
    <sym>Flag, Blue</sym>
    <type>Start</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
