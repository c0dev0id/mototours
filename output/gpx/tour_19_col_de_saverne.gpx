    <name>Neustadt a.d. Weinstraße</name>
    <desc>Through Pfälzerwald</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.348000" lon="7.850000">
    <name>Johanniskreuz</name>
    <desc>Forest crossroads</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.201000" lon="7.605000">
    <name>Pirmasens</name>
    <desc>Border region</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.052000" lon="7.430000">
    <name>Bitche</name>
