<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 05, Day 2: Belchen, Titisee &amp; Höllental Home</name>
    <desc>Ride through the Münstertal and climb the spectacular Belchen road to 1414 m—the finest panorama in the Black Forest. Descend to Schönau and Todtnau, then past the Feldberg to Titisee for lunch. Return through Hinterzarten and plunge into the Höllental—a dramatic gorge with sheer walls—to Freiburg. Return north via Offenburg and Baden-Baden.</desc>
  </metadata>
  <wpt lat="47.883000" lon="7.728000">
    <name>Staufen im Breisgau</name>
    <desc>Start day 2</desc>
    <type>Via</type>
  </wpt>
