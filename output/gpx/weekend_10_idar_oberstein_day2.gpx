<?xml version="1.0" encoding="UTF-8"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" version="1.1" creator="Hockenheim Motorcycle Tours">
  <metadata>
    <name>Weekend 10, Day 2: Hunsrück Heights &amp; Nahe Valley Home</name>
    <desc>Ride through Birkenfeld and climb to the Hunsrück Hochwald near Thalfang (the Erbeskopf at 816 m is the highest point in Rhineland-Palatinate). Cross the highlands to Morbach, then descend to the Nahe valley at Bad Sobernheim. Follow the Nahe east to Bad Kreuznach, cross through the Alsenz valley to the Pfalz, and return via Bad Dürkheim and Speyer.</desc>
  </metadata>
  <wpt lat="49.714000" lon="7.308000">
    <name>Idar-Oberstein</name>
    <desc>Start day 2</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.649000" lon="7.163000">
    <name>Birkenfeld</name>
    <desc>Hunsrück</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.754000" lon="7.010000">
    <name>Thalfang</name>
    <desc>Erbeskopf nearby</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.720000" lon="7.060000">
    <name>Hunsrück Hochwald</name>
    <desc>Wild highlands</desc>
    <sym>Restaurant</sym>
    <type>Midpoint</type>
  </wpt>
  <wpt lat="49.810000" lon="7.130000">
    <name>Morbach</name>
    <desc>Forest town</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.783000" lon="7.647000">
