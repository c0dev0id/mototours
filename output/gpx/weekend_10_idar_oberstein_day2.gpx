    <desc>Through to Pfalz</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.462000" lon="8.172000">
    <name>Bad Dürkheim</name>
    <desc>Wine barrel</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.317000" lon="8.431000">
    <name>Speyer</name>
    <desc>Cross Rhine</desc>
    <type>Via</type>
  </wpt>
  <wpt lat="49.322000" lon="8.548000">
    <name>Hockenheim</name>
    <desc>End – home</desc>
